{
  "extends": "@tsconfig/react-native/tsconfig.json",
  "compilerOptions": {
    "jsx": "react-native",
    "baseUrl": ".",
    "moduleSuffixes": [".native", ".android", ""],
    "paths": {
      "react": ["./node_modules/@types/react"],
      "react-native": ["./node_modules/react-native"],
      "@workspace/shared": ["../../packages/shared"],
      "@workspace/shared/*": ["../../packages/shared/*"]
    }
  },
  "include": ["src", "../../packages/shared"],
  "exclude": [
    "../../packages/shared/**/*.web.ts",
    "../../packages/shared/**/*.web.tsx"
  ]
}
